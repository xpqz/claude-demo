:Class ExampleApp
‚çù Example application using the Stark class.
‚çù
‚çù   app‚Üê‚éïNEW ExampleApp
‚çù   app.Start 8080
‚çù   app.Stop

    :Field Private router
    :Field Private db

    ‚àá Make
      :Access Public
      :Implements Constructor
     
      ‚çù Sample data
      db‚Üê(
          items:(
              (id:1 ‚ãÑ name:'Dyalog APL' ‚ãÑ price:0 ‚ãÑ tags:'language' 'array')
              (id:2 ‚ãÑ name:'SharpPlot' ‚ãÑ price:0 ‚ãÑ tags:'graphics' 'charting')
          )
      )
     
      ‚çù Stark setup
      router‚Üê##.Stark.New ()
      router.Info‚Üê(title:'Example Items API' ‚ãÑ version:'1.0.0')
     
      ‚çù '/'router.Get('Root'RootSchema)
      ‚çù '/items'router.Get('ListItems'ListItemsSchema)
      ‚çù '/items/{id}'router.Get('GetItem'GetItemSchema)
      ‚çù '/items'router.Post('CreateItem'CreateItemSchema)
      ‚çù '/items/{id}'router.Put('UpdateItem'UpdateItemSchema)
      ‚çù '/items/{id}'router.Delete('DeleteItem' DeleteItemSchema)
      ‚çù '/search'router.Get('SearchItems'SearchItemsSchema)
      ‚çù '/customer/{cust_id}/invoice/{inv_id}'router.Get('GetInvoice'GetInvoiceSchema)
      ‚çù VS:
      routes‚Üê[
        ‚çù Method     Endpoint                               Function       Schema
          'GET'      '/'                                    'Root'         RootSchema
          'GET'      '/items'                               'ListItems'    ListItemsSchema
          'GET'      '/items/{id}'                          'GetItem'      GetItemSchema
          'POST'     '/items'                               'CreateItem'   CreateItemSchema
          'PUT'      '/items/{id}'                          'UpdateItem'   UpdateItemSchema
          'DELETE'   '/items/{id}'                          'DeleteItem'   DeleteItemSchema
          'GET'      '/search'                              'SearchItems'  SearchItemsSchema
          'GET'      '/customer/{cust_id}/invoice/{inv_id}' 'GetInvoice'   GetInvoiceSchema
      ]
      router.Register routes
    ‚àá

    ‚àá Start port
      :Access Public
      router.Start port
    ‚àá

    ‚àá Stop
      :Access Public
      router.Stop
    ‚àá

    ‚àá r‚ÜêGetStark
      :Access Public
      r‚Üêrouter
    ‚àá

    ‚çù Handlers

    RootSchema‚Üê(
    summary: 'Health check'
    tags: ('status'‚ãÑ)
    parameters: ,‚äÇ(name:'verbose' ‚ãÑ in:'query' ‚ãÑ required:‚äÇ'false' ‚ãÑ schema:(type:'boolean'))
    )
    ‚àá result‚ÜêRoot req;verbose
      :Access Public
      verbose‚Üêreq.QueryParams ‚éïVGET‚äÇ(,'verbose')''
      :If verbose‚â°'true'
          result‚Üê(status:'ok' ‚ãÑ version:'1.0.0' ‚ãÑ uptime:'running')
      :Else
          result‚Üê(status:'ok')
      :EndIf
    ‚àá


    ListItemsSchema‚Üê(
    summary: 'List all items'
    tags: ('items'‚ãÑ)
    )
    ‚àá result‚ÜêListItems req
      :Access Public
      result‚Üê(items:db.items ‚ãÑ total:‚â¢db.items)
    ‚àá


    GetItemSchema‚Üê(
    summary: 'Get an item by ID'
    tags: ('items'‚ãÑ)
    )
    ‚àá result‚ÜêGetItem req;id;matches
      :Access Public
      id‚Üê‚äÉ2‚äÉ‚éïVFI req.PathParams.id
      matches‚Üê(db.items.id=id)/db.items
      :If 0=‚â¢matches
          req.Fail 404
          result‚Üê(detail:'Item not found')
      :Else
          result‚Üê‚äÉmatches
      :EndIf
    ‚àá


    CreateItemSchema‚Üê(
    summary: 'Create a new item'
    tags: ('items'‚ãÑ)
    body: (type: 'object' ‚ãÑ required: 'name' 'price' ‚ãÑ properties: (
    name:  (type: 'string')
    price: (type: 'number')
    ))
    response: (201 (type: 'object' ‚ãÑ properties: (
    id:    (type: 'integer')
    name:  (type: 'string')
    price: (type: 'number')
    tags:  (type: 'array' ‚ãÑ items: (type: 'string'))
    )))
    )
    ‚àá result‚ÜêCreateItem req;body;item
      :Access Public
      body‚Üêreq.Payload
      item‚Üê‚éïNS''
      item.id‚Üê1+‚åà/0,db.items.id
      item.name‚Üêbody.name
      item.price‚Üêbody.price
      item.tags‚Üê‚ç¨
      db.items,‚Üê‚äÇitem
      req.StatusCode‚Üê201
      result‚Üêitem
    ‚àá


    UpdateItemSchema‚Üê(
    summary: 'Update an item'
    tags: ('items'‚ãÑ)
    body: (type: 'object' ‚ãÑ required: 'name' 'price' ‚ãÑ properties: (
    name:  (type: 'string')
    price: (type: 'number')
    ))
    )
    ‚àá result‚ÜêUpdateItem req;id;idx;body
      :Access Public
      id‚Üê‚äÉ2‚äÉ‚éïVFI req.PathParams.id
      idx‚Üêdb.items.id‚ç≥id
      :If idx>‚â¢db.items
          req.Fail 404
          result‚Üê(detail:'Item not found')
      :Else
          body‚Üêreq.Payload
          (‚äÉdb.items[idx]).name‚Üêbody.name
          (‚äÉdb.items[idx]).price‚Üêbody.price
          result‚Üê‚äÉdb.items[idx]
      :EndIf
    ‚àá


    DeleteItemSchema‚Üê(
    summary: 'Delete an item'
    tags: ('items'‚ãÑ)
    )
    ‚àá result‚ÜêDeleteItem req;id;mask
      :Access Public
      id‚Üê‚äÉ2‚äÉ‚éïVFI req.PathParams.id
      mask‚Üêdb.items.id‚âÝid
      :If mask‚àß.=1
          req.Fail 404
          result‚Üê(detail:'Item not found')
      :Else
          db.items‚Üêmask/db.items
          result‚Üê(deleted:1 ‚ãÑ id:id)
      :EndIf
    ‚àá

    SearchItemsSchema‚Üê(
    summary: 'Search items'
    tags: ('search'‚ãÑ)
    )
    ‚àá result‚ÜêSearchItems req;q
      :Access Public
      q‚Üêreq.QueryParams ‚éïVGET‚äÇ(,'q')''
      result‚Üê(query:q ‚ãÑ results:'mock' 'data' ‚ãÑ total:2)
    ‚àá


    GetInvoiceSchema‚Üê(
    summary: 'Get a customer invoice'
    tags: ('invoices'‚ãÑ)
    )
    ‚àá result‚ÜêGetInvoice req
      :Access Public
      result‚Üê(customer:req.PathParams.cust_id ‚ãÑ invoice:req.PathParams.inv_id)
    ‚àá

:EndClass
