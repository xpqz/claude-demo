∇ Init
  Setup   ⍝ initialise #.db

  router←##.Stark.New ()
  router.Info←(title:'Example Items API' ⋄ version:'1.0.0')

  routes←[
  'GET' '/' 'Root' (
      summary: 'Health check'
      tags: ('status'⋄)
      parameters: ,⊂(name:'verbose' ⋄ in:'query' ⋄ required:⊂'false' ⋄ schema:(type:'boolean'))
  )
  'GET' '/items' 'ListItems' (
      summary: 'List all items'
      tags: ('items'⋄)
  )
  'GET' '/items/{id}' 'GetItem' (
      summary: 'Get an item by ID'
      tags: ('items'⋄)
  )
  'POST' '/items' 'CreateItem' (
      summary: 'Create a new item'
      tags: ('items'⋄)
      body: (type: 'object' ⋄ required: 'name' 'price' ⋄ properties: (
          name:  (type: 'string')
          price: (type: 'number')
      ))
      response: (201 (type: 'object' ⋄ properties: (
          id:    (type: 'integer')
          name:  (type: 'string')
          price: (type: 'number')
          tags:  (type: 'array' ⋄ items: (type: 'string'))
      )))
  )
  'PUT' '/items/{id}' 'UpdateItem'(
      summary: 'Update an item'
      tags: ('items'⋄)
      body: (type: 'object' ⋄ required: 'name' 'price' ⋄ properties: (
          name:  (type: 'string')
          price: (type: 'number')
      ))
  )
  'DELETE' '/items/{id}' 'DeleteItem'(
      summary: 'Delete an item'
      tags: ('items'⋄)
  )
  'GET' '/search' 'SearchItems'(
      summary: 'Search items'
      tags: ('search'⋄)
  )
  'GET' '/customer/{cust_id}/invoice/{inv_id}' 'GetInvoice'(
      summary: 'Get a customer invoice'
      tags: ('invoices'⋄)
  )
  ]
  router.Register routes
∇
