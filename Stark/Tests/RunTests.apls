#!/usr/bin/dyalogscript

вЋ•IOв†ђ1
вЋ•SE.(вЌЋвЉѓ2вЋ•FIX'/StartupSession.aplf',вЌЁ2вЋ•NQ#'GetEnvironment' 'DYALOG')

вЌќ Load framework
вЋ•SE.Link.Import '#' '../APLSource'

вЌќ Load HttpCommand and mocks
вЋ•SE.Link.Import '#' './HttpCommand.aplc'
вЋ•SE.Link.Import '#.Mocks' './Mocks'

вЌќ Load test runner
вЋ•SE.Link.Import '#' './RunHelper.apln'

вЌќ в”Ђв”Ђ Unit Tests в”Ђв”Ђ
вЋ•в†ђ'=== Unit Tests ==='
вЋ•SE.Link.Import '#.Unit' './Unit'
(uPass uFail)в†ђ#.RunHelper.Run #.Unit

вЌќ в”Ђв”Ђ Integration Tests в”Ђв”Ђ
вЋ•в†ђ''
вЋ•в†ђ'=== Integration Tests ==='
вЋ•SE.Link.Import '#' '../Examples'
portв†ђ19876
appв†ђвЋ•NEW #.ExampleClass.ExampleApp
routerв†ђapp.GetStark
router.ThreadModeв†ђ'DEBUG'
app.Start port
вЋ•DL 1

вЋ•SE.Link.Import '#.Integration' './Integration'
#.Integration.BaseURLв†ђ'http://localhost:',(вЌ•port)
(iPass iFail)в†ђ#.RunHelper.Run #.Integration

:Trap 0
    app.Stop
:EndTrap

вЌќ в”Ђв”Ђ Summary в”Ђв”Ђ
вЋ•в†ђ''
вЋ•в†ђ'=== Summary ==='
вЋ•в†ђ'Unit:        ',(вЌ•uPass),' passed, ',(вЌ•uFail),' failed'
вЋ•в†ђ'Integration: ',(вЌ•iPass),' passed, ',(вЌ•iFail),' failed'

:If 0<uFail+iFail
    вЋ•в†ђ'FAILED'
    вЋ•OFF 1
:Else
    вЋ•в†ђ'ALL PASSED'
    вЋ•OFF 0
:EndIf
