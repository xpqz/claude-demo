:Class Stark
вНЭ THIS PROJECT IS NOT FOR PUBLIC USE YET
вНЭ IT HAS NOT YET BEEN THOROUGHLY REVIEWED
вНЭ THIS PROJECT IS IN A BETA PHASE

вНЭ Fastify-style HTTP router for Dyalog APL, built on top of Jarvis.
вНЭ
вНЭ Usage:
вНЭ   вНЭ First define your functions, ListUsers, and GetUser, and CreateUser
вНЭ   routerвЖРStark.New ()
вНЭ   вНЭ Matrix mode (method path handler options per row):
вНЭ   router.Register [
вНЭ       'GET'  '/users'       'ListUsers'   ()
вНЭ       'GET'  '/users/{id}'  'GetUser'     ()
вНЭ       'POST' '/users'       'CreateUser'  opts   вНЭ opts is a namespace with metadata
вНЭ   ]
вНЭ   вНЭ Namespace vector mode (.method .path .handler, and optionally .spec):
вНЭ   router.Register (
вНЭ       (method: 'GET'  вЛД path: '/users'      вЛД handler: 'ListUsers')
вНЭ       (method: 'GET'  вЛД path: '/users/{id}' вЛД handler: 'GetUser')
вНЭ       (method: 'POST' вЛД path: '/users'      вЛД handler: 'CreateUser' вЛД spec: opts)
вНЭ   )
вНЭ   router.Start 8080

    :Field Public  Handlers      вНЭ namespace where handler functions live
    :Field Public  ThreadModeвЖР'' вНЭ DYALOG_JARVIS_THREAD: '' (Jarvis default), 0, 1, 'DEBUG', 'AUTO'
    :Field Public  Info          вНЭ namespace with title, version, description for OpenAPI info
    :Field Public  DebugвЖР0       вНЭ 0=all errors trapped, 1=stop on error in dispatch, 2=stop before user handler, 4=Jarvis framework debug, 8=Conga event logging, 16=stop before response, 32=Stark framework debug, 64=stop before routing
    :Field Public  OnErrorFnвЖР''  вНЭ if set, called as err OnErrorFn req after Fail 500 instead of resignalling; err is a вОХDMX clone
    :Field Private _routes       вНЭ vector of route descriptor namespaces
    :Field Private _jarvis       вНЭ underlying Jarvis instance

    вИЗ Make0
      :Access Public
      :Implements Constructor
      InfoвЖР(title: 'AStarkAPI' вЛД version: '1.0.0')
      HandlersвЖР1(86вМґ)'вОХTHIS'
      _routesвЖР0 4вНі''
      _jarvisвЖРвНђ
      '/openapi.json' Get '_OpenAPIHandler'
    вИЗ

    вИЗ instвЖРNew args
      :Access Public Shared
      instвЖРвОХNEW вОХTHIS
      inst.HandlersвЖР1(86вМґ)'вОХTHIS'
    вИЗ

    вНЭ Route registration
    вНЭ path router.Get 'HandlerName'
    вНЭ path router.Get ('HandlerName' opts)

    вИЗ {r}вЖРpath Get rarg
      :Access Public Instance
      rвЖР_Register 'GET' path rarg
    вИЗ

    вИЗ {r}вЖРpath Post rarg
      :Access Public Instance
      rвЖР_Register 'POST' path rarg
    вИЗ

    вИЗ {r}вЖРpath Put rarg
      :Access Public Instance
      rвЖР_Register 'PUT' path rarg
    вИЗ

    вИЗ {r}вЖРpath Delete rarg
      :Access Public Instance
      rвЖР_Register 'DELETE' path rarg
    вИЗ

    вИЗ {r}вЖРpath Patch rarg
      :Access Public Instance
      rвЖР_Register 'PATCH' path rarg
    вИЗ


    вИЗ {r}вЖР_Register(method path rarg);handler;options;norm;existing
      :Access Private Instance
      :If 1вЙ†вЙ°rarg                           вНЭ nested: ('HandlerName' options)
          (handler options)вЖРrarg
      :ElseIf вНХвНЫвЙ°rarg
          handlerвЖРrarg                     вНЭ simple string
          optionsвЖР()
      :Else
        вОХSIGNAL вКВ('EN' 11)('Message' ('STARK: Right argument to Register must be a string (handler name) or a 2-element vector (handler name, options)'))
      :EndIf
      вНЭ Check for duplicate routes: normalize {param} segments so {id} and {user_id} match
      normвЖР_NormalizePath path
      :If 0<вЙҐ_routes
          existingвЖР(_routes[;1]вИКвН•вОХC вКВmethod)вМњ_routes
          :If 0<вЙҐexisting
              :If (вКВnorm)вИК_NormalizePath¬®existing[;2]
                  вОХSIGNAL вКВ('EN' 11)('Message' ('STARK: Duplicate route: ',method,' ',path,' conflicts with an existing registration'))
              :EndIf
          :EndIf
      :EndIf
      rвЖР(
        method
        ,path
        handler
        options
      )
      _routesвН™вЖРr
    вИЗ

    вИЗ rвЖРRegister routes
      :Access Public
      вНЭ Matrix mode:   N√Ч4 matrix of (method path handler spec)
      вНЭ Namespace mode: vector of namespaces, each with .method .path .handler and optionally .spec
      :If 2=вНівНіroutes
        :If _routes[;2]{0вЙҐвЙҐвКГвИ©/{_NormalizePath¬®вНµ}¬®вНЇ вНµ}routes[;2]
            вОХSIGNAL вКВ('EN' 11)('Message' ('STARK: Duplicate routes detected'))
        :EndIf
        routes[;2]вЖР,¬®routes[;2]
        _routesвН™вЖР4вЖС[2]routes,()
      :Else
        :For ns :In ,routes
          :If 9=ns.вОХNC'spec'
              _Register ns.method ns.path (ns.handler ns.spec)
          :Else
              _Register ns.method ns.path ns.handler
          :EndIf
        :EndFor
      :EndIf
      rвЖР_routes
    вИЗ

    вНЭ Cover function for 7162вМґ (mangle string into valid APL name)
    _MangleвЖР{0(7162вМґ)вНµ}

    вНЭ Replace {param} segments with a placeholder so structurally identical paths match
    _NormalizePathвЖР{вНµ/вН®~+\вИК+/¬ѓ1 0вМљ¬®1 ¬ѓ1√ЧвЖУ'{}'вИШ.=вНµ}

    вИЗ rвЖР{value}DebugLevel level
    вНЭ monadic: return 1 if level is within Debug (powers of 2)
    вНЭ dyadic:  return value unless level is within Debug
      rвЖРвИ®/((7вНі2)вК§вКГDebug)вИ®.вИІ(7вНі2)вК§level
      :If 0вЙ†вОХNC'value'
          rвЖРvalue/вН®~r
      :EndIf
    вИЗ

    stopIfвЖР{1вИКвНµ:-вОХTRAPвЖР0 'C' 'вОХвЖР''Stopped for debugging... (Press Ctrl-Enter)''' вЛД shyвЖР0}

    вНЭ pattern pathMatch path вЖТ (matched pathParams)
    pathMatchвЖР{
        patSplit pathSplitвЖР'/'(вЙ†вКЖвКҐ)¬®вНЇ вНµ
        pathSplitвЙҐвН•вЙҐpatSplit:0()
        varMaskвЖР'{'=вКГ¬®patSplit
        вЙҐ/(вКВ~varMask)/¬®patSplit pathSplit:0()
        namesвЖР({1вЖУ¬ѓ1вЖУвНµ}¬®patSplit[вНЄvarMask])
        1(()вОХVSETвЖУвНЙвЖСnames(pathSplit[вНЄvarMask]))
    }

    вНЭ Route an incoming Jarvis request to the matching handler
    вИЗ resultвЖР_Dispatch req;routes;r;matched;pp;m;err
      :Access Public Instance
      stopIf DebugLevel 64                          вНЭ stop before routing
      routesвЖР(_routes[;1] вИКвН•вОХC вКВreq.Method)вМњ_routes
      :If 0=вЙҐroutes
          req.Fail 404
          resultвЖР(
            detail: 'Not Found'
          )
          :Return
      :EndIf
      m ppвЖР{(вКГвНµ) (вНµвКГвНЫ/2вКГвНµ)}вЖУвНЙвЖСroutes[;2] pathMatch¬®вКВreq.Endpoint
      rвЖРmвМњroutes
      :If 1вЙ†вЙҐpp
          req.Fail 404
          resultвЖР(
            detail: 'Not Found'
          )
          :Return
      :EndIf
      rвЖРr[1;]
      req.PathParamsвЖРвКГpp вНЭ Shouldn't have multiple matches.
      req.QueryParamsвЖР() вОХVSET вЖУreq.QueryParams
      _ParseBody req
      :If '_'=вКГ3вКГr
          resultвЖР(вНО3вКГr)req          вНЭ internal handler (on Stark)
      :Else
          :If DebugLevel 32
              вОХвЖР'STARK: ',req.Method,' ',req.Endpoint,' вЖТ ',3вКГr
          :EndIf
          stopIf DebugLevel 2              вНЭ stop before user handler
          :Trap 0 DebugLevel 1             вНЭ disable trap if bit 1 set (stop on error)
              resultвЖР(HandlersвНО3вКГr)req
          :Else
              :If ~0вИКвНіOnErrorFn
                  errвЖР()вОХNS вОХDMX          вНЭ deep clone вОХDMX before req.Fail may alter it
                  req.Fail 500
                  resultвЖРerr(HandlersвНОOnErrorFn)req
              :Else
                  вОХSIGNALвКВвОХDMX.(('EN'EN)('EM'EM)('Message'(OSError{вНµ,2вМљ(√ЧвЙҐвКГвНђвНі2вМљвНЇ,вКВ'')/'") ("',вКГвНђвНі2вМљвНЇ}Message))) вНЭ RESIGNAL
              :EndIf
          :EndTrap
      :EndIf
    вИЗ

    вИЗ _ParseBody req;pairs;p;name;value;fd
      :Access Private Instance
      вНЭ Parse the request body into req.Payload.
      вНЭ Jarvis ParsePayload is disabled to prevent crashes on empty bodies
      вНЭ with content-type headers (common with htmx DELETE/PUT).
      :If 0вИКвНіreq.Body вЛД :Return вЛД :EndIf
      :Select req.ContentType
      :Case 'application/json'
          req.PayloadвЖРвОХJSON req.Body
      :Case 'application/x-www-form-urlencoded'
          fdвЖРвОХNS ''
          pairsвЖР'&'(вЙ†вКЖвКҐ)req.Body
          :For p :In pairs
              name valueвЖР2вЖС('='(вЙ†вКЖвКҐ)p),вКВ''
              nameвЖРreq.URLDecode name
              :If ~0вИКвНіvalue вЛД valueвЖРreq.URLDecode value вЛД :EndIf
              :If 0=fd.вОХNC name вЛД fd{вНЇвНОвНµ,'вЖРвНђ'}name вЛД :EndIf
              fd(name{вНЇвНОвНЇвНЇ,',вЖРвНµ'})value
          :EndFor
          req.PayloadвЖРfd
      :EndSelect
    вИЗ

    вНЭ OpenAPI spec generation

    вИЗ rвЖРOpenAPI
      :Access Public Instance
      rвЖР_BuildOpenAPI
    вИЗ

    вИЗ resultвЖР_OpenAPIHandler req
      :Access Public Instance
      resultвЖР_BuildOpenAPI
    вИЗ

    вИЗ specвЖР_BuildOpenAPI;paths;r;pathKey;pathNS;method;op;opts;segs;varMask;param;pNS;ct;code;schemaNS;e;respNS;respKey;ctKey
      :Access Private Instance
      вНЭ _Mangle mangles strings into valid APL names; вОХJSON will unmangle them
      specвЖР(
        openapi: '3.0.3'
        info: Info
      )
      ctKeyвЖР_Mangle'application/json'

      pathsвЖР()
      :For r :In вЖУ_routes
          :If '_'=вКГ3вКГr вЛД :Continue вЛД :EndIf   вНЭ skip internal routes

          вНЭ Get or create path object
          pathKeyвЖР_Mangle 2вКГr
          :If 0=paths.вОХNCвКВpathKey
              paths вОХVSET вКВpathKey ()
          :EndIf
          pathNSвЖРpaths вОХVGET pathKey

          вНЭ Build operation object
          methodвЖРвОХC 1вКГr
          opвЖР(
            parameters: вНђ
            responses: ()
          )

          вНЭ Map metadata from route options
          optsвЖР4вКГr
          op.operationIdвЖР3вКГr

          вНЭ Extract path parameters from {param} segments
          вНЭ If opts.params.{name} exists, its schema overrides the default 'string'
          segsвЖР'/'(вЙ†вКЖвКҐ)2вКГr
          varMaskвЖР'{'=вКГ¬®segs
          :For param :In {1вЖУ¬ѓ1вЖУвНµ}¬®varMask/segs
              :If 9=вОХNC'opts' вЛД :AndIf 9=opts.вОХNC'params' вЛД :AndIf 9=opts.params.вОХNCвКВparam
                  pNSвЖР(name: param вЛД in: 'path' вЛД required: (вКВ'true') вЛД schema: (opts.paramsвНОparam))
              :Else
                  pNSвЖР(name: param вЛД in: 'path' вЛД required: (вКВ'true') вЛД schema: (type: 'string'))
              :EndIf
              op.parameters,вЖРвКВpNS
          :EndFor
          :If 9=вОХNC'opts'
              :If 2=opts.вОХNC'operationId'  вЛД op.operationIdвЖРopts.operationId  вЛД :EndIf
              :If 2=opts.вОХNC'summary'      вЛД op.summaryвЖРopts.summary          вЛД :EndIf
              :If 2=opts.вОХNC'description'  вЛД op.descriptionвЖРopts.description  вЛД :EndIf
              :If 2вЙ§opts.вОХNC'parameters'   вЛД op.parameters,вЖРopts.parameters   вЛД :EndIf
              :If 2=opts.вОХNC'tags'
                :If 2=вЙ°opts.tags
                  op.tagsвЖРopts.tags
                :Else
                  вОХSIGNAL вКВ'tags must be a vector of character vectors. Depth 2'
                :EndIf
              :EndIf
              

              вНЭ Request body schema
              :If 9=opts.вОХNC'body'
                  ctвЖР() вОХVSET вКВctKey (schema: opts.body)
                  op.requestBodyвЖР(required: (вКВ'true') вЛД content: ct)
              :EndIf

              вНЭ Success response: (statusCode schema)
              :If 2вЙ§opts.вОХNC'response'
                  (code schemaNS)вЖРopts.response
                  ctвЖР() вОХVSET вКВctKey (schema: schemaNS)
                  respNSвЖР(description: 'Successful response' вЛД content: ct)
                  respKeyвЖР_MangleвНХcode
                  op.responses вОХVSET вКВrespKey respNS
              :EndIf

              вНЭ Error responses: vector of (statusCode description) pairs
              :If 2вЙ§opts.вОХNC'errors'
                  :For e :In opts.errors
                      respKeyвЖР_MangleвНХвКГe
                      op.responses вОХVSET вКВrespKey (description: 2вКГe)
                  :EndFor
              :EndIf
          :EndIf
          :If 0=вЙҐop.parameters вЛД op.вОХEX'parameters' вЛД :EndIf

          вНЭ Default 200 response if none specified
          :If 0=вЙҐop.responses.вОХNL ¬ѓ2 ¬ѓ9
              respKeyвЖР_Mangle'200'
              op.responses вОХVSET вКВrespKey (description: 'Successful response')
          :EndIf

          pathNS вОХVSET вКВmethod op
      :EndFor

      spec.pathsвЖРpaths
    вИЗ


    вИЗ Start port;code;j
      :Access Public Instance
      codeвЖРвОХNS ''
      code.instвЖРвОХTHIS
      code.GetвЖР{inst._Dispatch вНµ}
      code.PostвЖР{inst._Dispatch вНµ}
      code.PutвЖР{inst._Dispatch вНµ}
      code.DeleteвЖР{inst._Dispatch вНµ}
      code.PatchвЖР{inst._Dispatch вНµ}
      :If _jarvisвЙ°вНђ
          jвЖРвОХNEW (вКГвКГвОХCLASS вОХTHIS).##.Jarvis
          _jarvisвЖРj
      :Else
          jвЖР_jarvis
      :EndIf
      j.PortвЖРport
      j.ParadigmвЖР'REST'
      j.CodeLocationвЖРcode
      j.RESTFailProcessingвЖР1
      j.ParsePayloadвЖР0
      j.DebugвЖР+/(1 4 8 16)√Ч1=2|вМКDebug√Ј1 4 8 16   вНЭ forward bits 1,4,8,16; bit 2 is replaced by Stark's bit 64/2
      :If ~0вИКвНіOnErrorFn
          :If 3вЙ†вМК|Handlers.вОХNCвКВOnErrorFn
              вОХSIGNAL вКВ('EN' 11)('Message' ('STARK: OnErrorFn "',OnErrorFn,'" not found in Handlers'))
          :ElseIf (0<Handlers.вОХNCвКВOnErrorFn)вИІ~вИІ/(вКГHandlers.вОХAT OnErrorFn)вИК¬®1(2 ¬ѓ2)0
              вОХSIGNAL вКВ('EN' 11)('Message' ('STARK: OnErrorFn "',OnErrorFn,'" must be a result-returning dyadic function'))
          :EndIf
      :EndIf
      :If ''вЙҐThreadMode
          j.DYALOG_JARVIS_THREADвЖРThreadMode
      :EndIf
      j.Start
    вИЗ

    вИЗ Stop
      :Access Public Instance
      _jarvis.Stop
    вИЗ

    вИЗ rвЖРGetJarvis
      :Access Public Instance
      rвЖР_jarvis
    вИЗ

    вИЗ rвЖРRoutes
      :Access Public Instance
      rвЖР('_'вЙ†вКГ¬®_routes[;3])вМњ_routes
    вИЗ

:EndClass
