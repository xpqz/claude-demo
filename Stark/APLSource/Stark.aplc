:Class Stark
тНЭ THIS PROJECT IS NOT FOR PUBLIC USE YET
тНЭ IT HAS NOT YET BEEN THOROUGHLY REVIEWED
тНЭ THIS PROJECT IS IN A BETA PHASE

тНЭ Fastify-style HTTP router for Dyalog APL, built on top of Jarvis.
тНЭ
тНЭ Usage:
тНЭ   тНЭ First define your functions, ListUsers, and GetUser, and CreateUser
тНЭ   routerтЖРStark.New ()
тНЭ   тНЭ Matrix mode (method path handler options per row):
тНЭ   router.Register [
тНЭ       'GET'  '/users'       'ListUsers'   ()
тНЭ       'GET'  '/users/{id}'  'GetUser'     ()
тНЭ       'POST' '/users'       'CreateUser'  opts   тНЭ opts is a namespace with metadata
тНЭ   ]
тНЭ   тНЭ Namespace vector mode (.method .path .handler, and optionally .spec):
тНЭ   router.Register (
тНЭ       (method: 'GET'  тЛД path: '/users'      тЛД handler: 'ListUsers')
тНЭ       (method: 'GET'  тЛД path: '/users/{id}' тЛД handler: 'GetUser')
тНЭ       (method: 'POST' тЛД path: '/users'      тЛД handler: 'CreateUser' тЛД spec: opts)
тНЭ   )
тНЭ   router.Start 8080

    :Field Public  Handlers      тНЭ namespace where handler functions live
    :Field Public  ThreadModeтЖР'' тНЭ DYALOG_JARVIS_THREAD: '' (Jarvis default), 0, 1, 'DEBUG', 'AUTO'
    :Field Public  Info          тНЭ namespace with title, version, description for OpenAPI info
    :Field Public  DebugтЖР0       тНЭ 0=all errors trapped, 1=stop on error in dispatch, 2=stop before user handler, 4=Jarvis framework debug, 8=Conga event logging, 16=stop before response, 32=Stark framework debug, 64=stop before routing
    :Field Public  OnErrorFnтЖР''  тНЭ if set, called as err OnErrorFn req after Fail 500 instead of resignalling; err is a тОХDMX clone
    :Field Private _routes       тНЭ vector of route descriptor namespaces
    :Field Private _jarvis       тНЭ underlying Jarvis instance

    тИЗ Make0
      :Access Public
      :Implements Constructor
      InfoтЖР(title: 'AStarkAPI' тЛД version: '1.0.0')
      HandlersтЖР1(86тМ╢)'тОХTHIS'
      _routesтЖР0 4тН┤''
      _jarvisтЖРтНм
      '/openapi.json' Get '_OpenAPIHandler'
    тИЗ

    тИЗ instтЖРNew args
      :Access Public Shared
      instтЖРтОХNEW тОХTHIS
      inst.HandlersтЖР1(86тМ╢)'тОХTHIS'
    тИЗ

    тНЭ Route registration
    тНЭ path router.Get 'HandlerName'
    тНЭ path router.Get ('HandlerName' opts)

    тИЗ {r}тЖРpath Get rarg
      :Access Public Instance
      rтЖР_Register 'GET' path rarg
    тИЗ

    тИЗ {r}тЖРpath Post rarg
      :Access Public Instance
      rтЖР_Register 'POST' path rarg
    тИЗ

    тИЗ {r}тЖРpath Put rarg
      :Access Public Instance
      rтЖР_Register 'PUT' path rarg
    тИЗ

    тИЗ {r}тЖРpath Delete rarg
      :Access Public Instance
      rтЖР_Register 'DELETE' path rarg
    тИЗ

    тИЗ {r}тЖРpath Patch rarg
      :Access Public Instance
      rтЖР_Register 'PATCH' path rarg
    тИЗ


    тИЗ {r}тЖР_Register(method path rarg);handler;options;norm;existing
      :Access Private Instance
      :If 1тЙатЙбrarg                           тНЭ nested: ('HandlerName' options)
          (handler options)тЖРrarg
      :ElseIf тНХтНЫтЙбrarg
          handlerтЖРrarg                     тНЭ simple string
          optionsтЖР()
      :Else
        тОХSIGNAL тКВ('EN' 11)('Message' ('STARK: Right argument to Register must be a string (handler name) or a 2-element vector (handler name, options)'))
      :EndIf
      тНЭ Check for duplicate routes: normalize {param} segments so {id} and {user_id} match
      normтЖР_NormalizePath path
      :If 0<тЙв_routes
          existingтЖР(_routes[;1]тИКтНетОХC тКВmethod)тМ┐_routes
          :If 0<тЙвexisting
              :If (тКВnorm)тИК_NormalizePath┬иexisting[;2]
                  тОХSIGNAL тКВ('EN' 11)('Message' ('STARK: Duplicate route: ',method,' ',path,' conflicts with an existing registration'))
              :EndIf
          :EndIf
      :EndIf
      rтЖР(
        method
        ,path
        handler
        options
      )
      _routesтНктЖРr
    тИЗ

    тИЗ rтЖРRegister routes
      :Access Public
      тНЭ Matrix mode:   N├Ч4 matrix of (method path handler spec)
      тНЭ Namespace mode: vector of namespaces, each with .method .path .handler and optionally .spec
      :If 2=тН┤тН┤routes
        :If _routes[;2]{0тЙвтЙвтКГтИй/{_NormalizePath┬итН╡}┬итН║ тН╡}routes[;2]
            тОХSIGNAL тКВ('EN' 11)('Message' ('STARK: Duplicate routes detected'))
        :EndIf
        routes[;2]тЖР,┬иroutes[;2]
        _routesтНктЖР4тЖС[2]routes,()
      :Else
        :For ns :In ,routes
          :If 9=ns.тОХNC'spec'
              _Register ns.method ns.path (ns.handler ns.spec)
          :Else
              _Register ns.method ns.path ns.handler
          :EndIf
        :EndFor
      :EndIf
      rтЖР_routes
    тИЗ

    тНЭ Cover function for 7162тМ╢ (mangle string into valid APL name)
    _MangleтЖР{0(7162тМ╢)тН╡}

    тНЭ Replace {param} segments with a placeholder so structurally identical paths match
    _NormalizePathтЖР{тН╡/тНи~+\тИК+/┬п1 0тМ╜┬и1 ┬п1├ЧтЖУ'{}'тИШ.=тН╡}

    тИЗ rтЖР{value}DebugLevel level
    тНЭ monadic: return 1 if level is within Debug (powers of 2)
    тНЭ dyadic:  return value unless level is within Debug
      rтЖРтИи/((7тН┤2)тКдтКГDebug)тИи.тИз(7тН┤2)тКдlevel
      :If 0тЙатОХNC'value'
          rтЖРvalue/тНи~r
      :EndIf
    тИЗ

    stopIfтЖР{1тИКтН╡:-тОХTRAPтЖР0 'C' 'тОХтЖР''Stopped for debugging... (Press Ctrl-Enter)''' тЛД shyтЖР0}

    тНЭ pattern pathMatch path тЖТ (matched pathParams)
    pathMatchтЖР{
        patSplit pathSplitтЖР'/'(тЙатКЖтКв)┬итН║ тН╡
        pathSplitтЙвтНетЙвpatSplit:0()
        varMaskтЖР'{'=тКГ┬иpatSplit
        тЙв/(тКВ~varMask)/┬иpatSplit pathSplit:0()
        namesтЖР({1тЖУ┬п1тЖУтН╡}┬иpatSplit[тН╕varMask])
        1(()тОХVSETтЖУтНЙтЖСnames(pathSplit[тН╕varMask]))
    }

    тНЭ Route an incoming Jarvis request to the matching handler
    тИЗ resultтЖР_Dispatch req;routes;r;matched;pp;m;err
      :Access Public Instance
      stopIf DebugLevel 64                          тНЭ stop before routing
      routesтЖР(_routes[;1] тИКтНетОХC тКВreq.Method)тМ┐_routes
      :If 0=тЙвroutes
          req.Fail 404
          resultтЖР(
            detail: 'Not Found'
          )
          :Return
      :EndIf
      m ppтЖР{(тКГтН╡) (тН╡тКГтНЫ/2тКГтН╡)}тЖУтНЙтЖСroutes[;2] pathMatch┬итКВreq.Endpoint
      rтЖРmтМ┐routes
      :If 1тЙатЙвpp
          req.Fail 404
          resultтЖР(
            detail: 'Not Found'
          )
          :Return
      :EndIf
      rтЖРr[1;]
      req.PathParamsтЖРтКГpp тНЭ Shouldn't have multiple matches.
      req.QueryParamsтЖР() тОХVSET тЖУreq.QueryParams
      :If '_'=тКГ3тКГr
          resultтЖР(тНО3тКГr)req          тНЭ internal handler (on Stark)
      :Else
          :If DebugLevel 32
              тОХтЖР'STARK: ',req.Method,' ',req.Endpoint,' тЖТ ',3тКГr
          :EndIf
          stopIf DebugLevel 2              тНЭ stop before user handler
          :Trap 0 DebugLevel 1             тНЭ disable trap if bit 1 set (stop on error)
              resultтЖР(HandlersтНО3тКГr)req
          :Else
              :If ~0тИКтН┤OnErrorFn
                  errтЖР()тОХNS тОХDMX          тНЭ deep clone тОХDMX before req.Fail may alter it
                  req.Fail 500
                  resultтЖРerr(HandlersтНОOnErrorFn)req
              :Else
                  тОХSIGNALтКВтОХDMX.(('EN'EN)('EM'EM)('Message'(OSError{тН╡,2тМ╜(├ЧтЙвтКГтНмтН┤2тМ╜тН║,тКВ'')/'") ("',тКГтНмтН┤2тМ╜тН║}Message))) тНЭ RESIGNAL
              :EndIf
          :EndTrap
      :EndIf
      тНЭ Jarvis REST handler omits Content-Length for empty responses,
      тНЭ causing clients to wait indefinitely. Set it explicitly.
      :If 0тИКтН┤result
          'Content-Length'req.SetHeader'0'
      :EndIf
    тИЗ

    тНЭ OpenAPI spec generation

    тИЗ rтЖРOpenAPI
      :Access Public Instance
      rтЖР_BuildOpenAPI
    тИЗ

    тИЗ resultтЖР_OpenAPIHandler req
      :Access Public Instance
      resultтЖР_BuildOpenAPI
    тИЗ

    тИЗ specтЖР_BuildOpenAPI;paths;r;pathKey;pathNS;method;op;opts;segs;varMask;param;pNS;ct;code;schemaNS;e;respNS;respKey;ctKey
      :Access Private Instance
      тНЭ _Mangle mangles strings into valid APL names; тОХJSON will unmangle them
      specтЖР(
        openapi: '3.0.3'
        info: Info
      )
      ctKeyтЖР_Mangle'application/json'

      pathsтЖР()
      :For r :In тЖУ_routes
          :If '_'=тКГ3тКГr тЛД :Continue тЛД :EndIf   тНЭ skip internal routes

          тНЭ Get or create path object
          pathKeyтЖР_Mangle 2тКГr
          :If 0=paths.тОХNCтКВpathKey
              paths тОХVSET тКВpathKey ()
          :EndIf
          pathNSтЖРpaths тОХVGET pathKey

          тНЭ Build operation object
          methodтЖРтОХC 1тКГr
          opтЖР(
            parameters: тНм
            responses: ()
          )

          тНЭ Map metadata from route options
          optsтЖР4тКГr
          op.operationIdтЖР3тКГr

          тНЭ Extract path parameters from {param} segments
          тНЭ If opts.params.{name} exists, its schema overrides the default 'string'
          segsтЖР'/'(тЙатКЖтКв)2тКГr
          varMaskтЖР'{'=тКГ┬иsegs
          :For param :In {1тЖУ┬п1тЖУтН╡}┬иvarMask/segs
              :If 9=тОХNC'opts' тЛД :AndIf 9=opts.тОХNC'params' тЛД :AndIf 9=opts.params.тОХNCтКВparam
                  pNSтЖР(name: param тЛД in: 'path' тЛД required: (тКВ'true') тЛД schema: (opts.paramsтНОparam))
              :Else
                  pNSтЖР(name: param тЛД in: 'path' тЛД required: (тКВ'true') тЛД schema: (type: 'string'))
              :EndIf
              op.parameters,тЖРтКВpNS
          :EndFor
          :If 9=тОХNC'opts'
              :If 2=opts.тОХNC'operationId'  тЛД op.operationIdтЖРopts.operationId  тЛД :EndIf
              :If 2=opts.тОХNC'summary'      тЛД op.summaryтЖРopts.summary          тЛД :EndIf
              :If 2=opts.тОХNC'description'  тЛД op.descriptionтЖРopts.description  тЛД :EndIf
              :If 2тЙдopts.тОХNC'parameters'   тЛД op.parameters,тЖРopts.parameters   тЛД :EndIf
              :If 2=opts.тОХNC'tags'
                :If 2=тЙбopts.tags
                  op.tagsтЖРopts.tags
                :Else
                  тОХSIGNAL тКВ'tags must be a vector of character vectors. Depth 2'
                :EndIf
              :EndIf
              

              тНЭ Request body schema
              :If 9=opts.тОХNC'body'
                  ctтЖР() тОХVSET тКВctKey (schema: opts.body)
                  op.requestBodyтЖР(required: (тКВ'true') тЛД content: ct)
              :EndIf

              тНЭ Success response: (statusCode schema)
              :If 2тЙдopts.тОХNC'response'
                  (code schemaNS)тЖРopts.response
                  ctтЖР() тОХVSET тКВctKey (schema: schemaNS)
                  respNSтЖР(description: 'Successful response' тЛД content: ct)
                  respKeyтЖР_MangleтНХcode
                  op.responses тОХVSET тКВrespKey respNS
              :EndIf

              тНЭ Error responses: vector of (statusCode description) pairs
              :If 2тЙдopts.тОХNC'errors'
                  :For e :In opts.errors
                      respKeyтЖР_MangleтНХтКГe
                      op.responses тОХVSET тКВrespKey (description: 2тКГe)
                  :EndFor
              :EndIf
          :EndIf
          :If 0=тЙвop.parameters тЛД op.тОХEX'parameters' тЛД :EndIf

          тНЭ Default 200 response if none specified
          :If 0=тЙвop.responses.тОХNL ┬п2 ┬п9
              respKeyтЖР_Mangle'200'
              op.responses тОХVSET тКВrespKey (description: 'Successful response')
          :EndIf

          pathNS тОХVSET тКВmethod op
      :EndFor

      spec.pathsтЖРpaths
    тИЗ


    тИЗ Start port;code;j
      :Access Public Instance
      codeтЖРтОХNS ''
      code.instтЖРтОХTHIS
      code.GetтЖР{inst._Dispatch тН╡}
      code.PostтЖР{inst._Dispatch тН╡}
      code.PutтЖР{inst._Dispatch тН╡}
      code.DeleteтЖР{inst._Dispatch тН╡}
      code.PatchтЖР{inst._Dispatch тН╡}
      :If _jarvisтЙбтНм
          jтЖРтОХNEW (тКГтКГтОХCLASS тОХTHIS).##.Jarvis
          _jarvisтЖРj
      :Else
          jтЖР_jarvis
      :EndIf
      j.PortтЖРport
      j.ParadigmтЖР'REST'
      j.CodeLocationтЖРcode
      j.RESTFailProcessingтЖР1
      j.DebugтЖР+/(1 4 8 16)├Ч1=2|тМКDebug├╖1 4 8 16   тНЭ forward bits 1,4,8,16; bit 2 is replaced by Stark's bit 64/2
      :If ~0тИКтН┤OnErrorFn
          :If 3тЙатМК|Handlers.тОХNCтКВOnErrorFn
              тОХSIGNAL тКВ('EN' 11)('Message' ('STARK: OnErrorFn "',OnErrorFn,'" not found in Handlers'))
          :ElseIf (0<Handlers.тОХNCтКВOnErrorFn)тИз~тИз/(тКГHandlers.тОХAT OnErrorFn)тИК┬и1(2 ┬п2)0
              тОХSIGNAL тКВ('EN' 11)('Message' ('STARK: OnErrorFn "',OnErrorFn,'" must be a result-returning dyadic function'))
          :EndIf
      :EndIf
      :If ''тЙвThreadMode
          j.DYALOG_JARVIS_THREADтЖРThreadMode
      :EndIf
      j.Start
    тИЗ

    тИЗ Stop
      :Access Public Instance
      _jarvis.Stop
    тИЗ

    тИЗ rтЖРGetJarvis
      :Access Public Instance
      rтЖР_jarvis
    тИЗ

    тИЗ rтЖРRoutes
      :Access Public Instance
      rтЖР('_'тЙатКГ┬и_routes[;3])тМ┐_routes
    тИЗ

:EndClass
