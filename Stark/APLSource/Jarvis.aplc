    ‚ąá (rc msg)‚ÜźStart;html
      :Access public
      :Trap 0 DebugLevel 1
          Log'Starting ',‚ćē2‚ÜĎVersion
          :If _started
              :If 0(,2)‚Č°LDRC.GetProp ServerName'Pause'
                  rc‚Üź1‚äÉLDRC.SetProp ServerName'Pause' 0
                  ‚Üí0 If(rc'Failed to unpause server')
                  (rc msg)‚Üź0 'Server resuming operations'
                  ‚Üí0
              :EndIf
              ‚Üí0 If(rc msg)‚Üź¬Į1 'Server thinks it''s already started'
          :EndIf
     
          :If _stop
              ‚Üí0 If(rc msg)‚Üź¬Į1 'Server is in the process of stopping'
          :EndIf
     
          :If 'CLEAR WS'‚Č°‚éēWSID
              :If ‚éēNEXISTS JarvisConfig
              :AndIf 2=‚äÉ1 ‚éēNINFO JarvisConfig
                  _rootFolder‚Üź‚äÉ1 ‚éēNPARTS JarvisConfig
              :Else
                  _rootFolder‚Üź‚äÉ1 ‚éēNPARTS SourceFile
              :EndIf
          :Else
              _rootFolder‚Üź‚äÉ1 ‚éēNPARTS ‚éēWSID
          :EndIf
     
          ‚Üí0 If(rc msg)‚ÜźLoadConfiguration JarvisConfig
          ‚Üí0 If(rc msg)‚ÜźCheckPort
          ‚Üí0 If(rc msg)‚ÜźCheckCodeLocation
          ‚Üí0 If(rc msg)‚ÜźSetup
          ‚Üí0 If(rc msg)‚ÜźLoadConga
     
          :If 19‚Č§APLVersion ‚ćĚ ‚éēTALLOC appeared in v19.0
              TokenBase‚Üź‚éēTALLOC 1 'Jarvis'
          :EndIf
     
          HTMLInterface‚Üź_htmlInterface ‚ćĚ because _rootFolder might have been set after the property
     
          :If EnableCORS ‚ćĚ if we've enabled CORS
          :AndIf ¬Į1‚ąäCORS_Methods ‚ćĚ but not set any pre-flighted methods
              :If Paradigm‚Č°'JSON'
                  CORS_Methods‚Üź'GET,POST,OPTIONS' ‚ćĚ allowed JSON methods are GET, POST, and OPTIONS
              :Else
                  CORS_Methods‚Üź1‚Üď‚ąä',',¬®RESTMethods[;1] ‚ćĚ allowed REST methods are what the service supports
              :EndIf
          :EndIf
     
          CORS_Methods‚Üźuc CORS_Methods
     
          ‚Üí0 If(rc msg)‚ÜźStartServer
     
          Log'Jarvis starting in "',Paradigm,'" mode on port ',‚ćēPort
          Log'Serving code in ',(‚ćēCodeLocation),(CodeSource‚ČĘ'')/' (populated with code from "',CodeSource,'")'
          Log(_htmlEnabled‚ąß_homePage)/'Click http',(~Secure)‚Üď's://',MyAddr,':',(‚ćēPort),' to access web interface'
     
      :Else ‚ćĚ :Trap
          (rc msg)‚Üź¬Į1 ‚éēDMX.EM
      :EndTrap
