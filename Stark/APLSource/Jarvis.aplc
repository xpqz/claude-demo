    :Section SessionHandler

    ‚ąá InitSessions
    ‚ćĚ initialize session handling
      :If 0‚Č†SessionTimeout ‚ćĚ are we using sessions?
          _sessions‚Üź‚ć¨
          _sessionsInfo‚Üź0 5‚ćī0 ‚ćĚ [;1] id, [;2] IP address, [;3] creation time, [;4] last active time, [;5] ref to session
          ‚éēRL‚Üź‚ć¨
          :If 0<SessionTimeout ‚ćĚ is there a timeout set?  0> means no timeout and sessions are managed by the application
              _sessionThread‚ÜźSessionMonitor&SessionTimeout
          :EndIf
      :EndIf
    ‚ąá

    ‚ąá SessionMonitor timeout;expired;dead
      :Repeat
          :If 0<‚ČĘ_sessionsInfo
              :Hold 'Sessions'
                  :If ‚ą®/expired‚ÜźSessionTimeout IsExpired _sessionsInfo[;4] ‚ćĚ any expired?
                  ‚ćĚ ‚Üď‚Üď‚Üď if a session expires, remove the namespace from _sessions
                  ‚ćĚ     but leave the entry in _sessionsInfo (removing the namespace reference)
                  ‚ćĚ     so that we can report to the user that his session timed out
                  ‚ćĚ     if he returns before SessionCleanupTime passes
                      _sessions~‚Üźexpired/_sessionsInfo[;5] ‚ćĚ remove from sessions list
                      (expired/_sessionsInfo[;5])‚Üź0        ‚ćĚ remove reference from _sessionsInfo
                  :EndIf
                  ‚ćĚ ‚Üď‚Üď‚Üď SessionCleanupTime is used to clean up _sessionsInfo after a session has expired
                  ‚ćĚ     In general SessionCleanupTime should be set to a value ‚Č• SessionTimeout
                  :If ‚ą®/dead‚Üź(0=_sessionsInfo[;5])‚ąßSessionCleanupTime IsExpired _sessionsInfo[;4] ‚ćĚ any expired sessions need their info removed?
                      _sessionsInfo‚ĆŅ‚ć®‚Üź~dead ‚ćĚ remove from _sessionsInfo
                  :EndIf
              :EndHold
          :EndIf
          {}‚éēDL timeout√ó60
      :EndRepeat
    ‚ąá

    MakeSessionId‚Üź{‚éēIO‚Üź0 ‚čĄ'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789'[(?20‚ćī62),5‚ÜĎ1‚Üď‚éēTS]}
    IsExpired‚Üź{‚ćļ‚Č§0: 0 ‚čĄ (Now-‚ćĶ)>(‚ćļ√ó60000)√∑86400000}

    ‚ąá r‚ÜźDateToIDNX ts
    ‚ćĚ Date to IDN eXtended (will be replaced by ‚éēDT when ‚éēDT is in the latest 3 versions of Dyalog APL)
      r‚Üź(2 ‚éēNQ'.' 'DateToIDN'(3‚ÜĎts))+(0 60 60 1000‚ä•¬Į4‚ÜĎ7‚ÜĎts)√∑86400000
    ‚ąá

    ‚ąá CreateSession req;ref;now;id;ts;rc
      id‚ÜźMakeSessionId''
      now‚ÜźNow
      :Hold 'Sessions'
          _sessions,‚Üźref‚Üź‚éēNS''
          _sessionsInfo‚ć™‚Üźid req.PeerAddr now now ref
          req.Session‚Üźref
      :EndHold
      :If ~0‚ąä‚ćīSessionInitFn
          :If 3=CodeLocation.‚éēNC SessionInitFn
              :Trap 0 DebugLevel 1
                  :Trap 85
                      stopIf DebugLevel 2
                      rc‚ÜźSessionInitFn CodeLocation.{1(85‚Ć∂)‚ćļ,' ‚ćĶ'}req
                  :Else ‚čĄ rc‚Üź0
                  :EndTrap
     
                  :If 0‚Č†rc
                      (_sessions _sessionsInfo)‚Üź¬Į1‚Üď¬®_sessions _sessionsInfo
                      ‚Üí0‚ä£('Session intialization returned ',‚ćērc)req.Fail 500
                  :EndIf
              :Else
                  ‚Üí0‚ä£(‚éēDMX.EM,' occurred during session initialization failed')req.Fail 500
              :EndTrap
          :Else
              ‚Üí0‚ä£('Session initialization function "',SessionInitFn,'" not found')req.Fail 500
          :EndIf
      :EndIf
      :If SessionUseCookie
          SessionIdHeader req.SetCookie id,(SessionTimeout>0)/'; Max-Age=',‚ćē‚Ćą60√óSessionTimeout
      :Else
          SessionIdHeader req.SetHeader id
      :EndIf
    ‚ąá

    ‚ąá r‚ÜźKillSession id;ind
    ‚ćĚ forcibly kill a session
    ‚ćĚ r is 1 if session was killed, 0 if not found
      :Hold 'Sessions'
          :If r‚Üź(‚ČĘ_sessionsInfo)‚Č•ind‚Üź_sessionsInfo[;1]‚ć≥‚äÜid
              _sessions~‚Üź_sessionsInfo[ind;5]
              _sessionsInfo‚ĆŅ‚ć®‚Üźind‚Č†‚ć≥‚ČĘ_sessionsInfo
          :EndIf
      :EndHold
    ‚ąá

    ‚ąá req TimeoutSession ind
    ‚ćĚ assumes :Hold 'Sessions' is set in calling environment
    ‚ćĚ removes session from _sessions and marks it as time out in _sessionsInfo
      _sessions~‚Üź_sessionsInfo[ind;5]
      _sessionsInfo‚ĆŅ‚Üźind‚Č†‚ć≥‚ČĘ_sessionsInfo
    ‚ąá

    ‚ąá ref‚ÜźGetSession req;id
      :Access public
      ref‚Üź''
      ‚Üí0‚ćī‚ć®0‚ąä‚ćīid‚ÜźGetSessionId req
      ref‚Üź(_sessionsInfo[;1]‚ć≥‚äāid)‚äÉ(_sessionsInfo[;5],‚äā'')
    ‚ąá

    ‚ąá id‚ÜźGetSessionId req
      :If SessionUseCookie
          id‚Üźreq.GetCookie SessionIdHeader
      :Else
          id‚Üźreq.GetHeader SessionIdHeader
      :EndIf
    ‚ąá

    ‚ąá r‚ÜźCheckSession req;ind;session;timedOut;id
    ‚ćĚ check for valid session (only called if SessionTimeout‚Č†0)
      r‚Üź1
      :Hold 'Sessions'
          id‚ÜźGetSessionId req
          ind‚Üź_sessionsInfo[;1]‚ć≥‚äāid
          ‚Üí0‚ćī‚ć®ind>‚ČĘ_sessionsInfo
     
          :If 0‚ąä‚ćīsession‚Üź‚äÉ_sessionsInfo[ind;5] ‚ćĚ already timed out (session was already removed from _sessions)
          :OrIf SessionTimeout IsExpired _sessionsInfo[ind;4] ‚ćĚ newly expired
              req TimeoutSession ind
              ‚Üí0
          :EndIf
    ‚ćĚ we have a valid session, refresh the cookie or set the header
          :If SessionUseCookie
              SessionIdHeader req.SetCookie id,(SessionTimeout>0)/'; Max-Age=',‚ćē‚Ćą60√óSessionTimeout
          :ElseIf
              SessionIdHeader req.SetHeader id
          :EndIf
          _sessionsInfo[ind;4]‚ÜźNow
          req.Session‚Üźsession
          r‚Üź0
      :EndHold
    ‚ąá

