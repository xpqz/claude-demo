              conx‚Üźobj(‚ć≥‚Üď‚ä£)'.'
              conn‚ÜźTokenForConnection‚ć£(~0‚ąä‚ćīconx)‚äĘconx ‚ćĚ connection (token) number - need to add 1 because connections start at 0
              :Select rc
              :Case 0
                  :Select evt
                  :Case 'Error'
                      _stop‚ÜźServerName‚Č°obj ‚ćĚ if we got an error on the server itself, signal to stop
                      :If 0‚Č†4‚äÉwres
                          Log'Server: DRC.Wait reported error ',(‚ćē4‚äÉwres),' on ',(2‚äÉwres),GetIP obj
                      :EndIf
                      RemoveConnection conx ‚ćĚ Conga closes object on an Error event
     
                  :Case 'Connect'
                      obj AddConnection conx
     
                  :CaseList 'HTTPHeader' 'HTTPTrailer' 'HTTPChunk' 'HTTPBody'
                      :If (DebugLevel 8)‚ąßevt‚Č°'HTTPHeader'
                          Log'Server: HTTPHeader Method/URL: ',‚ąä‚ćē2‚ÜĎ4‚äÉwres
                      :EndIf
                      :If 0‚Č†_connections.‚éēNC conx
                          ref‚Üź_connections‚ćéconx
                          wres ‚éēTPUT conn
                          _taskThreads‚Üź‚éēTNUMS‚ą©_taskThreads,ref{‚ćļ HandleRequest ‚ćĶ}&(obj conn)
                          ref.Time‚Üź‚éēAI[3]
                      :Else
                          Log'Server: Object ''_connections.',conx,''' was not found.'
                          {0:: ‚čĄ {}LDRC.Close ‚ćĶ}obj
                      :EndIf
     
                  :Case 'Closed'
                      RemoveConnection conx
     
                  :Case 'Timeout'
     
                  :Else ‚ćĚ unhandled event
                      Log'Server: Unhandled Conga event:'
                      Log fmtCongaEvent wres
                  :EndSelect ‚ćĚ evt
     
              :Case 1010 ‚ćĚ Object Not found
                  :If ~_stop
                      Log'Server: Object ''',ServerName,''' has been closed - Jarvis shutting down'
                      _stop‚Üź1
                  :EndIf
              :Else
                  Log'Server: Conga wait failed:'
                  Log fmtCongaEvent wres
              :EndSelect ‚ćĚ rc
     
              CleanupConnections
     
          :Else ‚ćĚ :Trap
              Log'*** Server error ',msg‚Üź1 ‚éēJSON‚ć†'Compact' 0‚äĘ‚éēDMX
              r‚Üź¬Į1 msg
              ‚ÜíExit
          :EndTrap
      :EndWhile
     
      r‚Üź0 'Server stopped'
     
     Exit:
     
      :If ~0‚ąä‚ćīAppCloseFn
          r‚ÜźCodeLocation‚ćéAppCloseFn
      :EndIf
     
      Close
      ‚éēTKILL _sessionThread
      (_stop _started _stopped)‚Üź0 0 1
    ‚ąá

    ‚ąá r‚ÜźTokenForConnection conx
    ‚ćĚ return token for connection name (CONnnnnnnnn)
      r‚Üź1+‚äÉ‚äÉ(//)‚éēVFI conx‚ą©‚éēD
      :If 0‚Č†TokenBase ‚ćĚ if ‚éēTALLOC is available...
          r‚Üź‚ćé,('<',(‚ćēTokenBase),'.>,ZI8')‚éēFMT r
      :EndIf
    ‚ąá

    ‚ąá obj AddConnection conx;IP;res
      :Hold '_connections'
          conx _connections.‚éēNS''
          _connections.index,‚Üźconx(‚éēAI[3])
          IP‚Üź''
          :Trap 0 DebugLevel 1
              :If 0=‚äÉres‚ÜźLDRC.GetProp obj'PeerAddr'
                  IP‚Üź2‚äÉ2‚äÉres
              :EndIf
          :EndTrap
          (_connections‚ćéconx).IP‚ÜźIP
      :EndHold
    ‚ąá

    ‚ąá RemoveConnection conx;ref
      :Hold '_connections'
          :If 0=_connections.‚éēNC conx
              Log'Attempt to remove non-existent connection ',‚ćēconx
          :Else
              ref‚Üź_connections‚ćéconx
              :If 9=|‚Ćäref.‚éēNC‚äā'Req'
              :AndIf ref.Req.KillOnDisconnect
                  ‚éēTKILL ref.Req.Thread
              :EndIf
          :EndIf
          _connections.‚éēEX conx
          _connections.index/‚ć®‚Üź_connections.index[1;]‚ČĘ¬®‚äāconx
      :EndHold
      CleanupTokens conx
    ‚ąá

    ‚ąá CleanupConnections;conxNames;timedOut;dead;kids;connecting;connected;killed
      :If _connections.lastCheck<‚éēAI[3]-ConnectionTimeout√ó1000
          killed‚Üź‚ć¨
          :Hold '_connections'
              connecting‚Üźconnected‚Üź‚ć¨
              :If ~0‚ąä‚ćīkids‚Üź2 2‚äÉLDRC.Tree ServerName ‚ćĚ retrieve children of server
              ‚ćĚ LDRC.Tree
              ‚ćĚ connecting ‚Üí status 3 1 - incoming connection
              ‚ćĚ connected  ‚Üí status 3 4 - connected connection
                  (connecting connected)‚Üź2‚ÜĎ{((2 2‚ćī3 1 3 4)‚ć™‚ćĶ[;2 3]){‚äā1‚Üď‚ćĶ}‚Ćł'' '',‚ćĶ[;1]}‚ÜĎ‚äÉ¬®kids
              :EndIf
              conxNames‚Üź_connections.index[1;]~connecting
              timedOut‚Üź_connections.index[1;]/‚ć®ConnectionTimeout<0.001√ó‚éēAI[3]-_connections.index[2;]
              :If ‚ą®/{~0‚ąä‚ćī‚ćĶ}¬®connected conxNames
                  :If ~0‚ąä‚ćītimedOut
                      timedOut/‚ć®‚Üź{6::1 ‚čĄ 0=(_connections‚ćé‚ćĶ).‚éēNC‚äā'Req'}¬®timedOut
                  :EndIf
                  :If ~0‚ąä‚ćīdead‚Üź(connected~conxNames),timedOut ‚ćĚ (connections not in the index), timed out
                      {0‚ąä‚ćī‚ćĶ: ‚čĄ {}LDRC.Close ServerName,'.',‚ćĶ}¬®dead ‚ćĚ attempt to close them
                  :EndIf
               ‚ćĚ remove timed out, or connections that are
                  _connections.‚éēEX killed‚Üź(conxNames~connected~dead),timedOut
                  _connections.index/‚ć®‚Üź_connections.index[1;]‚ąä_connections.‚éēNL ¬Į9
              :EndIf
              _connections.lastCheck‚Üź‚éēAI[3]
          :EndHold
          CleanupTokens killed
      :EndIf
    ‚ąá

    ‚ąá CleanupTokens conx
    ‚ćĚ remove any lingering tokens from dead/removed connections
      :If ~0‚ąä‚ćīconx
          conx‚Üź,‚äÜconx
          {}‚éēTGET ‚éēTPOOL‚ą©TokenForConnection¬®{‚äÉ¬Į1‚ÜĎ‚ćĶ(‚Č†‚äÜ‚ä£)'.'}¬®conx
      :EndIf
    ‚ąá

    :Section RequestHandling

    ‚ąá r‚ÜźErrorInfo
      :Trap 0
          r‚Üź‚ćēErrorInfoLevel‚ÜĎ‚éēDMX.(EM({‚ćĶ‚ÜĎ‚ć®‚ćĶ‚ć≥']'}2‚äÉDM))
      :Else
          r‚Üź''
      :EndTrap
    ‚ąá

    ‚ąá req‚ÜźMakeRequest args
    ‚ćĚ create a request, use MakeRequest '' for interactive debugging
    ‚ćĚ :Access public ‚ćĚ uncomment for debugging
      :If 0‚ąä‚ćīargs
          req‚Üź‚éēNEW Request
      :Else
          req‚Üź‚éēNEW Request args
      :EndIf
      req.(Server ErrorInfoLevel)‚Üź‚éēTHIS ErrorInfoLevel
    ‚ąá

    ‚ąá ns HandleRequest(obj conn);data;evt;obj;rc;cert;fn
      :Hold obj
          (rc obj evt data)‚Üź‚äÉ‚éēTGET conn ‚ćĚ from Conga.Wait
          :Select evt
          :Case 'HTTPHeader'
              ns.Req‚ÜźMakeRequest data
              ns.Req.Thread‚Üź‚éēTID
              ns.Req.PeerCert‚Üź''
              ns.Req.PeerAddr‚Üź2‚äÉ2‚äÉLDRC.GetProp obj'PeerAddr'
              ns.Req.Server‚Üź‚éēTHIS
     
              :If Secure
                  (rc cert)‚Üź2‚ÜĎLDRC.GetProp obj'PeerCert'
                  :If rc=0
                      ns.Req.PeerCert‚Üźcert
                  :Else
                      ns.Req.PeerCert‚Üź'Could not obtain certificate'
                  :EndIf
              :EndIf
     
          :Case 'HTTPBody'
              ‚ćĚ‚Üď‚Üď‚Üď if Req doesn't exist, it's because it was marked complete previously and removed, and we just ignore this event
              ‚ćĚ    this can happen in the case where:
              ‚ćĚ       - the request is a POST request
              ‚ćĚ       - and no content-length header was provided
              ‚ćĚ       - and transfer-encoding is not "chunked"
              ‚ćĚ Conga 3.5 addresses this by issuing and HTTPError event, but earlier Conga's
              ‚Üí0‚ćī‚ć®0=ns.‚éēNC'Req'
              ns.Req.Thread‚Üź‚éēTID
              ns.Req.ProcessBody data
          :Case 'HTTPChunk'
              ns.Req.Thread‚Üź‚éēTID
              ns.Req.ProcessChunk data
          :Case 'HTTPTrailer'
              ns.Req.Thread‚Üź‚éēTID
              ns.Req.ProcessTrailer data
          :EndSelect
     
          ns.Req.Thread‚Üź‚éēTID
     
          :If ns.Req.Complete
              :Select lc ns.Req.GetHeader'content-encoding' ‚ćĚ zipped request?
              :Case '' ‚ćĚ no encoding
                  :If ns.Req.Charset‚Č°'utf-8'
                      ns.Req.Body‚Üź'UTF-8'‚éēUCS ‚éēUCS ns.Req.Body
                  :EndIf
              :Case 'gzip'
                  ‚Üíresp If'gzip'Unzip ns.Req
              :Case 'deflate'
                  ‚Üíresp If'deflate'Unzip ns.Req
              :Else
                  ‚Üíresp‚ä£'Unsupported content-encoding'ns.Req.Fail 400
              :EndSelect
     
            ‚ćĚ Application-specified validation
              stopIf DebugLevel 4+2√ó~0‚ąä‚ćīValidateRequestFn
              :If 0‚Č†Validate ns.Req
                  ns.Req.Fail 400√óns.Req.Response.Status=0 ‚ćĚ default status 400 if not set by application
                  ‚Üíresp
              :EndIf
     
              ns.Req.Response.(Status‚Üź(Status 200)[1+Status=0]) ‚ćĚ if status was not already set, set to default
     
              fn‚Üź1‚Üď'.'@('/'‚ąė=)ns.Req.Endpoint
     
              fn RequestHandler ns ‚ćĚ RequestHandler is either HandleJSONRequest or HandleRESTRequest
     
     resp:
              ‚ćĚ if HTML interface is enabled, and there's a problem with the request, and we haven't already set a payload
              :If _htmlEnabled‚ąß(2=‚Ćä0.01√óns.Req.Response.Status)<0‚ąä‚ćīns.Req.Response.Payload
                  'content-type'ns.Req.SetHeader'text/html; charset=utf-8'
                  ns.Req.Response.Payload‚Üź'<h3>',(‚ćēns.Req.Response.((‚ćēStatus),' ',StatusText)),'</h3>'
              :EndIf
     
              obj Respond ns
     
          :EndIf
      :EndHold
    ‚ąá

    ‚ąá rc‚Üźtype Unzip req;n
    ‚ćĚ attempt to unzip the request payload
    ‚ćĚ req is the Request instance
    ‚ćĚ type is 'deflate' or 'gzip'
      n‚Üź¬Į2 ¬Į3['deflate' 'gzip'‚ć≥‚äātype]
      :Trap rc‚Üź0
          req.Body‚Üź‚éēUCS 256|n Zipper 83 ‚éēDR req.Body
      :Else
          ('Invalid payload for "',type,'" content-encoding')req.Fail 400
          rc‚Üź1
      :EndTrap
    ‚ąá

    ‚ąá fn HandleJSONRequest ns;payload;resp;valence;nc;debug;file;isGET
     
      ‚Üíhandle If~isGET‚Üź'get'‚Č°ns.Req.Method
     
      :If AllowGETs ‚ćĚ if we allow GETs
      :AndIf ~'.'‚ąäns.Req.Endpoint ‚ćĚ and the endpoint doesn't have a '.' (file extension)
          ‚Üíhandle If 3=‚Ćä|{0::0 ‚čĄ CodeLocation.‚éēNC‚äā‚ćĶ}fn ‚ćĚ handle it if there's a matching function for the endpoint
      :EndIf
     
      ‚ÜíEnd If'Request method should be POST'ns.Req.Fail 405√ó~_htmlEnabled
     
      ‚ÜíhandleHtml If~0‚ąä‚ćī_htmlFolder
      ns.Req.Response.Headers‚Üź1 2‚ćī'Content-Type' 'text/html; charset=utf-8'
      ns.Req.Response.Payload‚Üź'<!DOCTYPE html><html><head><meta content="text/html; charset=utf-8" http-equiv="Content-Type"><link rel="icon" href="data:,"></head><body><h2>400 Bad Request</h2></body></html>'
      ‚ÜíEnd If'Bad URI'ns.Req.Fail 400√ó~0‚ąä‚ćīfn ‚ćĚ either fail with a bad URI or exit if favicon.ico (no-op)
     
      :If 0‚ąä‚ćī_htmlRootFn
          ns.Req.Response.Payload‚ÜźHtmlPage
      :Else
          ns.Req.Response.Payload‚Üź{1 CodeLocation.(85‚Ć∂)_htmlRootFn,' ‚ćĶ'}ns.Req
      :EndIf
      ‚ÜíEnd
     
     handleHtml:
      :If (,'/')‚Č°ns.Req.Endpoint
          file‚Üź_htmlFolder,_htmlDefaultPage
      :Else
          file‚Üź_htmlFolder,('/'=‚ä£/ns.Req.Endpoint)‚Üďns.Req.Endpoint
      :EndIf
      file‚ÜźresolveFilename file
      file,‚Üź(isDir file)/'/',_htmlDefaultPage
      ‚ÜíEnd If ns.Req.Fail 400√ó~_htmlFolder begins file
      :If 0‚Č†ns.Req.Fail 404√ó~‚éēNEXISTS file
          ‚ÜíEnd If 0=Report404InHTML
          ns.Req.Response.Headers‚Üź1 2‚ćī'Content-Type' 'text/html; charset=utf-8'
          ns.Req.Response.Payload‚Üź'<h3>Not found: ',(file‚Üď‚ć®‚ČĘ_htmlFolder),'</h3>'
          ‚ÜíEnd
      :EndIf
      ns.Req.Response.Payload‚Üź''file
      'Content-Type'ns.Req.DefaultHeader ns.Req.ContentTypeForFile file
      ‚ÜíEnd
     
     handle:
      ‚ÜíEnd If HandleCORSRequest ns.Req
      ‚ÜíEnd If'No function specified'ns.Req.Fail 400√ó0‚ąä‚ćīfn
      ‚ÜíEnd If'Unsupported request method'ns.Req.Fail 405√ó(‚äāns.Req.Method)(~‚ąä)(~AllowGETs)‚Üď'get' 'post'
      ‚ÜíEnd If'Cannot accept query parameters'ns.Req.Fail 400√óAllowGETs‚ćĪ0‚ąä‚ćīns.Req.QueryParams
     
      :Select ns.Req.ContentType
     
      :Case 'application/json'
          :Trap 0 DebugLevel 1
              ns.Req.Payload‚Üź{0‚ąä‚ćī‚ćĶ:‚ćĶ ‚čĄ JSONin ‚ćĶ}ns.Req.Body
          :Else
              ‚ÜíEnd‚ä£'Could not parse payload as JSON'ns.Req.Fail 400
          :EndTrap
     
      :Case 'multipart/form-data'
          ‚ÜíEnd If'Content-Type should be "application/json"'ns.Req.Fail 400√ó~AllowFormData
          ‚ÜíEnd If 0‚Č†ParseMultipart ns.Req
     
      :Case 'application/x-www-form-urlencoded'
          ‚ÜíEnd If'Content-Type should be "application/json"'ns.Req.Fail 400√ó~AllowFormData
          ‚ÜíEnd If 0‚Č†ParseFormData ns.Req
     
      :Case ''
          ‚ÜíEnd If'No Content-Type specified'ns.Req.Fail 400√ó~isGET‚ąßAllowGETs
          :Trap 0 DebugLevel 1
              :If 0‚ąä‚ćīns.Req.QueryParams
                  ns.Req.Payload‚Üź''
              :ElseIf 1=‚ČĘ‚ćīns.Req.QueryParams ‚ćĚ if a vector, try to parse as JSON
                  ns.Req.Payload‚ÜźJSONin ns.Req.QueryParams
              :Else ‚ćĚ if a matrix it's [;1] name [;2] value
                  ns.Req.Payload‚ÜźJSONin 1‚ĆĹ'}{',1‚Üď‚ąä',',¬Į1‚ĆĹ':',‚ĆĹJSONout¬®ns.Req.QueryParams
              :EndIf
          :Else
              ‚ÜíEnd‚ä£'Could not parse query string as JSON'ns.Req.Fail 400
          :EndTrap
     
      :Else
          ‚ÜíEnd‚ä£('Content-Type should be "application/json"',AllowFormData/' or "multipart/form-data"')ns.Req.Fail 400
      :EndSelect
     
      ‚ÜíEnd If CheckAuthentication ns.Req
     
      ‚ÜíEnd If('Invalid function "',fn,'"')ns.Req.Fail CheckFunctionName fn
      ‚ÜíEnd If('Invalid function "',fn,'"')ns.Req.Fail 404√ó3‚Č†‚Ćä|{0::0 ‚čĄ CodeLocation.‚éēNC‚äā‚ćĶ}fn  ‚ćĚ is it a function?
      valence‚Üź|‚äÉCodeLocation.‚éēAT fn
      nc‚ÜźCodeLocation.‚éēNC‚äāfn
      ‚ÜíEnd If('"',fn,'" is not a monadic result-returning function')ns.Req.Fail 400√ó(1 1 0‚ČĘ√óvalence)>(0‚ąß.=valence)‚ąß3.3=nc
     
      resp‚Üź''
      :Trap 0 DebugLevel 1
          :Trap 85
              :If (2=valence[2])>3.3=nc ‚ćĚ dyadic and not tacit
                  stopIf DebugLevel 2
                  resp‚Üźns.Req{0 CodeLocation.(85‚Ć∂)'‚ćļ ',fn,' ‚ćĶ'}ns.Req.Payload ‚ćĚ intentional stop for application-level debugging
              :Else
                  stopIf DebugLevel 2
                  resp‚Üź{0 CodeLocation.(85‚Ć∂)fn,' ‚ćĶ'}ns.Req.Payload ‚ćĚ intentional stop for application-level debugging
              :EndIf
          :Else ‚ćĚ no result from the endpoint
              :If 0‚ąä‚ćīns.Req.Response.Payload ‚ćĚ no payload?
              :AndIf 200=ns.Req.Response.Status  ‚ćĚ endpoint did not change the status
                  ‚ÜíEnd‚ä£ns.Req.Fail 204 ‚ćĚ no content
              :EndIf
          :EndTrap
      :Else
          ‚ÜíEnd‚ä£ErrorInfo ns.Req.Fail 500
      :EndTrap
     
      ‚ÜíEnd If 204=ns.Req.Response.Status ‚ćĚ exit on no content
     
     ‚ćĚ Exit if
     ‚ćĚ        ‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď no response from endpoint,
     ‚ćĚ and              ‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď endpoint did not set payload
     ‚ćĚ and                                          ‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď‚Üď endpoint failed the request
      ‚ÜíEnd If(0‚ąä‚ćīresp)‚ąß(0‚ąä‚ćīns.Req.Response.Payload)‚ąß2‚Č†‚Ćä0.01√óns.Req.Response.Status
     
     ‚ćĚ If the endpoint explicitly sets the payload, use it in preference to any endpoint result
      :If 0‚ąä‚ćīns.Req.Response.Payload
          ns.Req.Response.Payload‚Üźresp
      :EndIf
     
      stopIf DebugLevel 2√ó~0‚ąä‚ćīPostProcessFn
      :Trap 85 ‚ćĚ ignore any result from PostProcess
          {}{1(85‚Ć∂)'PostProcess ‚ćĶ'}ns.Req ‚ćĚ call postprocessing
      :EndTrap
     
      'Content-Type'ns.Req.DefaultHeader DefaultContentType ‚ćĚ set the header if not set
      :If ‚ą®/'application/json'‚ć∑ns.Req.(Response.Headers GetHeader'content-type') ‚ćĚ if the response is JSON
          ToJSON ns.Req ‚ćĚ convert payload
      :EndIf
     
      :If 0‚ąä‚ćīns.Req.Response.Payload
          'Content-Length'ns.Req.DefaultHeader 0
      :EndIf
     End:
    ‚ąá

    ‚ąá rc‚ÜźParseMultipart req
    ‚ćĚ cover for ParseMultipartForm so we can call it from JSON or REST handling
      :Trap 0 DebugLevel 1
          req.Payload‚ÜźParseMultipartForm req
          rc‚Üź200‚Č†req.Response.Status ‚ćĚ bail if parsing fails
      :Else
          rc‚Üź1‚ä£'Could not parse payload as "multipart/form-data"'req.Fail 400
      :EndTrap
    ‚ąá

    ‚ąá formData‚ÜźParseMultipartForm req;boundary;body;part;headers;payload;disposition;type;name;filename;tmp
      boundary‚Üźcrlf,'--',req.Boundary ‚ćĚ the HTTP standard prepends '--' to the boundary
      body‚Üźreq.Body
      formData‚Üź‚éēNS''
      body‚Üź‚äÉbody splitOnFirst boundary,'--'  ‚ćĚ drop off trailing boundary ('--' is appended to the trailing boundary)
      :For part :In (crlf,body)splitOn boundary ‚ćĚ split into parts
          (headers payload)‚Üźpart splitOnFirst crlf,crlf
          (disposition type)‚Üźdeb¬®2‚ÜĎheaders splitOn crlf
          (name filename)‚Üźdeb¬®2‚ÜĎ1‚Üďdisposition splitOn';'
          name‚Üź'"'~‚ć®2‚äÉname splitOn'='
          name‚Üď‚ć®‚Üź¬Į2√ó'[]'‚Č°¬Į2‚ÜĎname ‚ćĚ drop any trailing [] (we handle arrays automatically)
          :If ('.'‚ąäname)‚ą®¬Į1=‚éēNC name
              ‚Üí0‚ä£('Invalid form field name "',name,'" for Jarvis')req.Fail 400
          :EndIf
          tmp‚Üź‚éēNS''
          filename‚Üź'"'~‚ć®2‚äÉ2‚ÜĎfilename splitOn'='
          tmp.(Name Filename)‚Üźname filename
          tmp.Content‚Üźpayload
          tmp.Content_Type‚Üźdeb 2‚äÉ2‚ÜĎtype splitOn':'
          :If 0=formData.‚éēNC name ‚čĄ formData{‚ćļ‚ćé‚ćĶ,'‚Üź‚ć¨'}name ‚čĄ :EndIf
          formData(name{‚ćļ‚ćé‚ćļ‚ćļ,',‚Üź‚ćĶ'})tmp
      :EndFor
    ‚ąá

    ‚ąá rc‚ÜźParseFormData req
    ‚ćĚ cover for ParseUrlencodedForm so we can call it from JSON or REST handling
      :Trap 0 DebugLevel 1
          req.Payload‚ÜźParseUrlencodedForm req
          rc‚Üź200‚Č†req.Response.Status ‚ćĚ bail if parsing fails
      :Else
          rc‚Üź1‚ä£'Could not parse payload as "application/x-www-form-urlencoded"'req.Fail 400
      :EndTrap
    ‚ąá

    ‚ąá formData‚ÜźParseUrlencodedForm req;data;name;value
    ‚ćĚ parse application/x-www-form-urlencoded content
      formData‚Üź‚éēNS''
