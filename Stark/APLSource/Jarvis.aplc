    ‚ąá r‚ÜźHtmlPage;endpoints
      :Access public
      r‚ÜźScriptFollows
‚ćĚ<!DOCTYPE html>
‚ćĚ<html>
‚ćĚ<head>
‚ćĚ<meta content="text/html; charset=utf-8" http-equiv="Content-Type">
‚ćĚ<link rel="icon" href="data:,">
‚ćĚ<title>Jarvis</title>
‚ćĚ <style>
‚ćĚ   body {color:#000000;background-color:white;font-family:Verdana;margin-left:0px;margin-top:0px;}
‚ćĚ   button {display:inline-block;font-size:1.1em;}
‚ćĚ   legend {font-size:1.1em;}
‚ćĚ   select {font-size:1.1em;}
‚ćĚ   label  {display:inline-block;margin-bottom:7px;}
‚ćĚ   div {padding:5px;}
‚ćĚ   label input textarea button #result {display:flex;}
‚ćĚ   textarea {width:100%;font-size:18px;}
‚ćĚ   #result {font-size:18px;}
‚ćĚ   #result code {white-space:pre-line;word-wrap:break-word;}
‚ćĚ </style>
‚ćĚ</head>
‚ćĚ<body>
‚ćĚ<div id="content">
‚ćĚ<fieldset>
‚ćĚ  <legend>Request</legend>
‚ćĚ  <form id="myform">
‚ćĚ    <div>
‚ćĚ      <label for="function">Endpoint:</label>
‚ćĚ      ‚ĆĻ
‚ćĚ    </div>
‚ćĚ    <div>
‚ćĚ      <label for="payload">JSON Payload:</label>
‚ćĚ      <textarea id="payload" name="payload"></textarea>
‚ćĚ    </div>
‚ćĚ    <div>
‚ćĚ      <button onclick="doit()" type="button">Send</button>
‚ćĚ    </div>
‚ćĚ  </form>
‚ćĚ</fieldset>
‚ćĚ<fieldset>
‚ćĚ  <legend>Response</legend>
‚ćĚ  <div id="result">
‚ćĚ  </div>
‚ćĚ</fieldset>
‚ćĚ<script>
‚ćĚfunction doit() {
‚ćĚ  document.getElementById("result").innerHTML = "";
‚ćĚ  var payload = document.getElementById("payload").value;
‚ćĚ  if (0 == payload.length) {
‚ćĚ    document.getElementById("result").innerHTML = "<span style='color:red;'>Please enter a valid JSON payload</span>";
‚ćĚ    } else {
‚ćĚ    var xhttp = new XMLHttpRequest();
‚ćĚ    var fn = document.getElementById("function").value;
‚ćĚ    fn = (0 == fn.indexOf('/')) ? fn : '/' + fn;
‚ćĚ
‚ćĚ    xhttp.open("POST", fn, true);
‚ćĚ    xhttp.setRequestHeader("content-type", "application/json; charset=utf-8");
‚ćĚ
‚ćĚ    xhttp.onreadystatechange = function() {
‚ćĚ      if (this.readyState == 4){
‚ćĚ        if (this.status == 200) {
‚ćĚ          try {
‚ćĚ            var resp = "<pre><code>" + JSON.stringify(JSON.parse(this.responseText)) + "</code></pre>";;
‚ćĚ          }
‚ćĚ          catch(err) {
‚ćĚ            var resp = "<pre><code>" + this.responseText + "</code></pre>";
‚ćĚ          }
‚ćĚ        } else {
‚ćĚ          var resp = "<span style='color:red;'>" + this.statusText + "</span> <pre><code>" + this.responseText + "</code></pre>";
‚ćĚ        }
‚ćĚ        document.getElementById("result").innerHTML = resp;
‚ćĚ      }
‚ćĚ    }
‚ćĚ    xhttp.send(document.getElementById("payload").value);
‚ćĚ  }
‚ćĚ}
‚ćĚ</script>
‚ćĚ</div>
‚ćĚ</body>
‚ćĚ</html>
      endpoints‚Üź{‚ćĶ/‚ć®0=CheckFunctionName ‚ćĶ}EndPoints CodeLocation
      :If 0‚ąä‚ćīendpoints
          endpoints‚Üź'<b>No Endpoints Found</b>'
      :Else
          endpoints‚Üź‚ąä{'<option value="',‚ćĶ,'">',‚ćĶ,'</option>'}¬®'/'@('.'=‚äĘ)¬®endpoints
          endpoints‚Üź'<select id="function" name="function">',endpoints,'</select>'
      :EndIf
      r‚Üźendpoints{i‚Üź‚ćĶ‚ć≥'‚ĆĻ' ‚čĄ ((i-1)‚ÜĎ‚ćĶ),‚ćļ,i‚Üď‚ćĶ}r
