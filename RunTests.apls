#!/usr/bin/dyalogscript

вЋ•IOв†ђ1
вЋ•SE.(вЌЋвЉѓ2вЋ•FIX'/StartupSession.aplf',вЌЁ2вЋ•NQ#'GetEnvironment' 'DYALOG')

вЌќ Import framework and app
вЋ•SE.Link.Import '#' './Stark/APLSource'
вЋ•SE.Link.Import '#' './APLSource'

вЌќ Import test infrastructure
вЋ•SE.Link.Import '#.Mocks' './tests/Mocks'
вЋ•SE.Link.Import '#' './tests/RunHelper.apln'
вЋ•SE.Link.Import '#' './Stark/Tests/HttpCommand.aplc'

вЌќ Unit tests
вЋ•SE.Link.Import '#.Unit' './tests/Unit'
вЋ•в†ђ'=== Unit Tests ==='
(uPass uFail)в†ђ#.RunHelper.Run #.Unit

вЌќ Integration tests
вЋ•в†ђ''
вЋ•в†ђ'=== Integration Tests ==='
portв†ђ18900+?100
staticRootв†ђвЉѓ1 вЋ•NPARTS './static/'
appв†ђвЋ•NEW #.TodoApp staticRoot
app.RegisterTestRoutes
rв†ђapp.GetStark
r.ThreadModeв†ђ'DEBUG'
app.Start port
вЋ•DL 1

вЋ•SE.Link.Import '#.Integration' './tests/Integration'
#.Integration.BaseURLв†ђ'http://localhost:',(вЌ•port)
(iPass iFail)в†ђ#.RunHelper.Run #.Integration

:Trap 0
    app.Stop
:EndTrap

вЌќ Summary
вЋ•в†ђ''
вЋ•в†ђ'=== Summary ==='
вЋ•в†ђ'Unit:        ',(вЌ•uPass),' passed, ',(вЌ•uFail),' failed'
вЋ•в†ђ'Integration: ',(вЌ•iPass),' passed, ',(вЌ•iFail),' failed'

:If 0<uFail+iFail
    вЋ•в†ђ'FAILED'
    вЋ•OFF 1
:Else
    вЋ•в†ђ'ALL PASSED'
    вЋ•OFF 0
:EndIf
